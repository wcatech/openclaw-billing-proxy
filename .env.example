# OAuth token from Claude Code (overrides credential file lookup)
# Get yours: run `claude auth status` or check ~/.claude/.credentials.json
# Two options: set OAUTH_TOKEN here, OR rely on the ~/.claude volume mount in docker-compose.yml
# OAUTH_TOKEN=sk-ant-...

# Override proxy port (default: 18801)
# PROXY_PORT=18801

# Bind address (default: 127.0.0.1, localhost only)
# Docker Compose sets this to 0.0.0.0 automatically -- do NOT change
# unless you understand the security implications.
# Outside Docker, leave this unset to bind to localhost only.
# PROXY_HOST=127.0.0.1
